            "warning": 30,
            "critical": 15
        },
        "format": "<span font='JetBrainsMono NF'>{icon}</span>  {capacity}%",
        "format-full": "<span font='JetBrainsMono NF'>{icon}</span>  {capacity}%",
        "format-charging": "п—§ {capacity}%",
