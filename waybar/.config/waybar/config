        "tooltip": false,
        "on-click": "flatpak run org.gnome.Calendar",
    },
    "cpu": {
        "format": "<span font='Font Awesome 6 Free 11'>п‹›</span> {usage}%",
        "tooltip": false
    },
    "memory": {
