        // "exec": "python3 $HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    },
    "custom/power": {
        "format" : "<span font='Font Awesome 6 Free 11'>пЂ‘</span>",
