      "format-icons": {
        "default": "пѓ§",
        "performance": "пѓ§",
        "balanced": "п‰Ћ",
        "power-saver": "пЃ¬"
      }
    },
    "bluetooth": {
        "format": "<span font='Font Awesome 6 Free 11'>пЉ”</span>  {status}",
        "format-disabled": "<span font='JetBrainsMono NF'>у°‚І</span> {status}",
        "format-connected": "<span font='Font Awesome 6 Free 11'>у°‚±</span> {device_alias}",
